# =============================================================================
# interference — .gitignore (TypeScript + Bun)
# =============================================================================

# --- Environment / secrets ---------------------------------------------------
.env
.env.*
!.env.example

# --- Node / Bun --------------------------------------------------------------
node_modules/
dist/
build/
*.tsbuildinfo
.bun/
# bun.lock / bun.lockb ARE committed (riproducibilità).

# --- Internal / non versionato (scelta progetto) -----------------------------
# Configurazione e doc operative interne all'agente: fuori dal repo pubblico.
/CLAUDE.md
/.claude
/docs
# Asset sorgente del brand (la landing usa solo i file in site/assets/).
/logo
# Note di lavoro per developer.
/iterazioni
/fix

# --- Logs --------------------------------------------------------------------
logs/
*.log

# --- OS / editor -------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# --- Misc secrets ------------------------------------------------------------
*.pem
*.key
*.p12
interference.json
